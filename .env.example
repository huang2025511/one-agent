# ============================================================
# One-Agent 环境变量模板
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env 填入你的配置
#
# 提示：敏感值（API Key 等）支持 Fernet 加密，前缀加 "enc:"
# 加密密钥通过 ONE_AGENT_ENCRYPTION_KEY 环境变量设置
# ============================================================

# ── 核心配置 ───────────────────────────────────────────────
ONE_AGENT_CONFIG=config/default_config.yaml   # 配置文件路径（显式指定，最高优先级；设此项时 ONE_AGENT_ENV 不生效）
ONE_AGENT_ENV=                                # 环境切换: dev | staging | prod（加载 config/{env}_config.yaml，并与 default 深度合并）
ONE_AGENT_SETUP=                              # 设为 1 强制重跑 setup 向导（即使已配置过 key 也重新选提供商）
ONE_AGENT_DATA_DIR=                           # 覆盖数据目录（日志/数据库/执行产物等，默认 ./data）
ONE_AGENT_API_KEY=                            # REST API 认证密钥（空=不启用）
ONE_AGENT_ENCRYPTION_KEY=                     # Fernet 加密密钥（用于加密配置中的敏感值）
ONE_AGENT_LANGUAGE=zh                         # 默认语言: en | zh
ONE_AGENT_TIMEZONE=Asia/Shanghai              # 时区: UTC | Asia/Shanghai | America/New_York

# ── LLM API Keys（填你使用的即可，其他留空） ─────────────
# 推荐免费/低成本提供商：
#   1. SenseNova (商汤)  — https://platform.sensenova.com
#   2. DeepSeek (深度求索) — https://platform.deepseek.com
#   3. DashScope (阿里百炼) — https://dashscope.console.aliyun.com

SENSENOVA_API_KEY=                            # 商汤日日新
DEEPSEEK_API_KEY=                             # 深度求索
DASHSCOPE_API_KEY=                            # 阿里百炼（千问系列）
OPENAI_API_KEY=                               # OpenAI
ANTHROPIC_API_KEY=                            # Anthropic (Claude)
OPENROUTER_API_KEY=                           # OpenRouter（聚合多模型）
GROQ_API_KEY=                                 # Groq
TOGETHER_API_KEY=                             # Together AI

# 国内其他提供商
ZHIPU_API_KEY=                                # 智谱 AI (GLM)
MOONSHOT_API_KEY=                             # 月之暗面 (Kimi)
BAICHUAN_API_KEY=                             # 百川智能
MINIMAX_API_KEY=                              # 稀宇科技 (MiniMax)
SPARK_API_KEY=                                # 讯飞星火
WENXIN_API_KEY=                               # 百度文心
HUNYUAN_API_KEY=                              # 腾讯混元
STEPFUN_API_KEY=                              # 阶跃星辰

# 本地模型（无需 API Key）
OLLAMA_HOST=http://localhost:11434            # Ollama 本地模型地址

# ── 消息网关 Tokens ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=                           # Telegram 机器人 Token
DISCORD_BOT_TOKEN=                            # Discord 机器人 Token
SLACK_BOT_TOKEN=                              # Slack 机器人 Token
SLACK_SIGNING_SECRET=                         # Slack 签名密钥
WECOM_WEBHOOK_KEY=                            # 企业微信 Webhook Key
WECOM_CORP_ID=                                # 企业微信 Corp ID（应用模式）
WECOM_AGENT_ID=                               # 企业微信 Agent ID
WECOM_SECRET=                                 # 企业微信 Secret
DINGTALK_WEBHOOK_URL=                         # 钉钉 Webhook URL
DINGTALK_CLIENT_ID=                           # 钉钉 Client ID
DINGTALK_CLIENT_SECRET=                       # 钉钉 Client Secret
FEISHU_WEBHOOK_URL=                           # 飞书 Webhook URL
FEISHU_APP_ID=                                # 飞书 App ID
FEISHU_APP_SECRET=                            # 飞书 App Secret

# ── 安全设置 ─────────────────────────────────────────────
SYSTEM_EXECUTOR_PASSWORD=                     # 系统执行器密码（用于解锁危险命令）
SYSTEM_EXECUTOR_PASSWORD_HASH=                # 密码哈希（优先于明文密码）

# ── 数据库/存储 ──────────────────────────────────────────
# 默认使用 SQLite，无需配置。如需外部数据库可在此扩展
# DATABASE_URL=

# ── 代理 ─────────────────────────────────────────────────
HTTPS_PROXY=                                  # HTTPS 代理
HTTP_PROXY=                                   # HTTP 代理
NO_PROXY=                                     # 不走代理的地址
